---
const year = new Date().getFullYear();
---

<footer>
  <div class="footer-inner">
    <p class="muted">
      &copy; {year} Trove Collections, LLC. All rights reserved.
    </p>
    <nav>
      <a href="/about">About</a>
      <a href="/disclosure">Affiliate Disclosure</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--rule);
    padding: 2rem 1.5rem;
    background: var(--bg);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
  }
  nav {
    display: flex;
    gap: 1.5rem;
    font-size: 0.9rem;
  }
  nav a {
    color: var(--muted);
    border: 0;
  }
  nav a:hover { color: var(--ink); }
  @media (min-width: 720px) {
    .footer-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
