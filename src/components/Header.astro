---
const regions = [
  { label: 'East Asia', href: '/collections/east-asia' },
  { label: 'Europe', href: '/collections/europe' },
  { label: 'Latin America', href: '/collections/latin-america' },
  { label: 'Levant', href: '/collections/levant' },
  { label: 'Oceania', href: '/collections/oceania' },
  { label: 'Travel Gear', href: '/collections/travel-gear' },
  { label: "Eris's Picks", href: '/collections/eris' },
];
---

<header>
  <div class="header-inner">
    <a href="/" class="brand">
      <span class="brand-name">Trove Collections</span>
      <span class="brand-tag">Curated by Eris's circle</span>
    </a>
    <nav>
      {regions.map(r => (
        <a href={r.href}>{r.label}</a>
      ))}
      <a href="/about" class="muted-link">About</a>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .brand {
    border: 0;
    color: var(--ink);
    display: flex;
    flex-direction: column;
  }
  .brand-name {
    font-family: ui-serif, Georgia, serif;
    font-size: 1.5rem;
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .brand-tag {
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    font-size: 0.95rem;
  }
  nav a {
    color: var(--ink);
    border: 0;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
  }
  nav a:hover {
    border-bottom-color: var(--accent);
    opacity: 1;
  }
  nav a.muted-link {
    color: var(--muted);
    margin-left: auto;
  }
  @media (min-width: 720px) {
    .header-inner {
      flex-direction: row;
      align-items: baseline;
      justify-content: space-between;
      padding: 1.5rem;
    }
  }
</style>
