---
const regions = [
  { label: 'East Asia', href: '/collections/east-asia' },
  { label: 'Europe', href: '/collections/europe' },
  { label: 'Latin America', href: '/collections/latin-america' },
  { label: 'Levant', href: '/collections/levant' },
  { label: 'North America', href: '/collections/north-america' },
  { label: 'Oceania', href: '/collections/oceania' },
  { label: 'Travel Gear', href: '/collections/travel-gear' },
  { label: 'Crew Gear', href: '/collections/crew-gear' },
  { label: 'Business Attire', href: '/ladies-business-attire' },
  { label: 'Beauty', href: '/collections/beauty' },
  { label: "Eris's Picks", href: '/collections/eris' },
];
---

<header>
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Trove Collections — home">
      <img
        src="/images/brand/trove-logo.png"
        alt="Trove Collections — curated by Eris's circle"
        class="brand-logo"
        width="150"
        height="150"
      />
    </a>
    <nav>
      {regions.map(r => (
        <a href={r.href}>{r.label}</a>
      ))}
      <a href="/stories" class="muted-link">Stories</a>
      <a href="/about" class="muted-link">About</a>
    </nav>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
  }
  .header-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  .brand {
    border: 0;
    display: block;
  }
  .brand-logo {
    width: 156px;
    height: auto;
    display: block;
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    gap: 1.25rem;
    font-size: 0.95rem;
  }
  nav a {
    color: var(--ink);
    border: 0;
    padding-bottom: 2px;
    border-bottom: 1px solid transparent;
  }
  nav a:hover {
    border-bottom-color: var(--accent);
    opacity: 1;
  }
  nav a.muted-link {
    color: var(--muted);
  }
  @media (min-width: 760px) {
    .header-inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    nav {
      justify-content: flex-end;
      max-width: 72%;
    }
  }
</style>
