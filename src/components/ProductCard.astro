---
export interface Props {
  name: string;
  curator: string;
  blurb: string;
  photo?: string;
  additionalPhotos?: string[];
  affiliateUrl?: string;
  pendingPhoto?: boolean;
  slug: string;
}

const { name, curator, blurb, photo, additionalPhotos, affiliateUrl, pendingPhoto, slug } = Astro.props;
const photoCount = 1 + (additionalPhotos?.length ?? 0);
const hasMultiple = (additionalPhotos?.length ?? 0) > 0 && photo && !pendingPhoto;
---

<article class="card">
  <a href={`/item/${slug}`} class="card-photo-link">
    {photo && !pendingPhoto ? (
      <img src={photo} alt={name} loading="lazy" />
    ) : (
      <div class="photo-placeholder">
        <span>Photo coming soon</span>
      </div>
    )}
    {hasMultiple && (
      <span class="photo-count" aria-label={`${photoCount} photos`}>+{photoCount - 1}</span>
    )}
  </a>
  <div class="card-body">
    <h3><a href={`/item/${slug}`}>{name}</a></h3>
    <p class="curator muted">Picked by {curator}</p>
    <p class="blurb">{blurb}</p>
    {affiliateUrl && (
      <a href={affiliateUrl} class="shop-link" rel="sponsored noopener" target="_blank">
        Shop this &rarr;
      </a>
    )}
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding-bottom: 1.5rem;
  }
  .card-photo-link {
    display: block;
    border: 0;
    background: #FFFFFF;
    border: 1px solid var(--rule);
    border-radius: 4px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    position: relative;
  }
  .photo-count {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    background: rgba(31, 27, 22, 0.78);
    color: #FAF6F0;
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }
  .card-photo-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    font-size: 0.9rem;
    font-style: italic;
    background: var(--bg);
  }
  .card-body h3 a {
    color: var(--ink);
    border: 0;
  }
  .card-body h3 a:hover { color: var(--accent); }
  .curator {
    font-size: 0.85rem;
    font-style: italic;
    margin: 0;
  }
  .blurb {
    font-size: 0.95rem;
    margin: 0.5rem 0 0.75rem;
  }
  .shop-link {
    display: inline-block;
    align-self: flex-start;
    background: var(--accent);
    color: #FFFFFF;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    padding: 0.55rem 1.25rem;
    border-radius: 6px;
    border: 0;
    margin-top: 0.25rem;
  }
  .shop-link:hover {
    opacity: 0.88;
    color: #FFFFFF;
  }
</style>
