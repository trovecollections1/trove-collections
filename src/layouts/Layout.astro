---
export interface Props {
  title: string;
  description?: string;
  /**
   * Render the FTC affiliate disclosure banner at the top of <main>.
   * Per Trevor Crow (Doida Crow Legal, 2026-05-25) the short disclosure must
   * be hard-to-miss and appear with the endorsement, not only above the
   * footer. Default true. Pages without any affiliate links (About, Contact,
   * the disclosure page itself) should pass false.
   */
  topDisclosure?: boolean;
  /** Path or URL to the social-share / Pinterest Rich Pin image. Resolved to absolute against the site. */
  image?: string;
  /** Open Graph type — "website" for general pages, "article" for item/story pages. */
  ogType?: string;
}

const {
  title,
  description = "Curated travel-inspired finds personally used by Eris's circle of pilot curators. Real picks, no algorithm.",
  topDisclosure = true,
  image,
  ogType = "website",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image ?? "/images/brand/trove-logo.png", Astro.site).href;

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclosureBanner from '../components/DisclosureBanner.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon-tc.png?v=2" />
    <link rel="apple-touch-icon" href="/favicon-tc.png?v=2" />
    <meta name="generator" content={Astro.generator} />
    <meta name="fo-verify" content="67a58a85-4878-4688-bd1e-ecc7551fdd91" />
    <meta name="impact-site-verification" value="39ecdaf7-a6a1-4178-bdf4-787d534ba88c" />
    <meta name="p:domain_verify" content="8dd3b3b8e2697f48d43da92dc73b3f04" />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph / Pinterest Rich Pins -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Trove Collections" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    {topDisclosure && <DisclosureBanner />}
    <main>
      <slot />
    </main>
    <DisclosureBanner />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    --bg: #FAF6F0;        /* same warm off-white as product photos */
    --ink: #1F1B16;
    --muted: #6B6258;
    --rule: #E8DFD3;
    --accent: #8B5E3C;    /* warm brown — heritage feel without being precious */
    --max-width: 1100px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: ui-serif, Georgia, "Iowan Old Style", "Apple Garamond", "Times New Roman", serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  h1, h2, h3 {
    font-family: ui-serif, Georgia, serif;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.75rem; }
  h2 { font-size: 1.5rem; margin: 2.5rem 0 1rem; }
  h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }

  p { margin-bottom: 1rem; }

  a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  a:hover { opacity: 0.7; }

  .muted { color: var(--muted); font-size: 0.95rem; }

  hr {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 2rem 0;
  }
</style>
