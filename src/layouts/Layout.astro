---
export interface Props {
  title: string;
  description?: string;
  /**
   * Render the FTC affiliate disclosure banner at the top of <main>.
   * Per Trevor Crow (Doida Crow Legal, 2026-05-25) the short disclosure must
   * be hard-to-miss and appear with the endorsement, not only above the
   * footer. Default true. Pages without any affiliate links (About, Contact,
   * the disclosure page itself) should pass false.
   */
  topDisclosure?: boolean;
  /** Path or URL to the social-share / Pinterest Rich Pin image. Resolved to absolute against the site. */
  image?: string;
  /** Open Graph type — "website" for general pages, "article" for item/story pages. */
  ogType?: string;
  /** Preload this above-the-fold hero image for a faster LCP (e.g. homepage hero). */
  heroPreload?: string;
}

const {
  title,
  description = "Curated travel-inspired finds personally used by Eris's circle of pilot curators. Real picks, no algorithm.",
  topDisclosure = true,
  image,
  ogType = "website",
  heroPreload,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image ?? "/images/brand/trove-logo.png", Astro.site).href;

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import DisclosureBanner from '../components/DisclosureBanner.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {heroPreload && <link rel="preload" as="image" href={heroPreload} fetchpriority="high" />}
    <link rel="icon" type="image/png" href="/favicon-tc.png?v=2" />
    <link rel="apple-touch-icon" href="/favicon-tc.png?v=2" />
    <meta name="generator" content={Astro.generator} />
    <meta name="fo-verify" content="67a58a85-4878-4688-bd1e-ecc7551fdd91" />
    <meta name="impact-site-verification" value="39ecdaf7-a6a1-4178-bdf4-787d534ba88c" />
    <meta name="p:domain_verify" content="8dd3b3b8e2697f48d43da92dc73b3f04" />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph / Pinterest Rich Pins -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Trove Collections" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{title}</title>
  </head>
  <body>
    <Header />
    {topDisclosure && <DisclosureBanner />}
    <main>
      <slot />
    </main>
    <DisclosureBanner />
    <Footer />

    <!-- Lightbox: click any figure photo to view it full-size; click or Esc to close. -->
    <script is:inline>
      (function () {
        var overlay;
        function ensureOverlay() {
          if (overlay) return overlay;
          overlay = document.createElement('div');
          overlay.className = 'tc-lightbox';
          overlay.setAttribute('role', 'dialog');
          overlay.setAttribute('aria-label', 'Enlarged photo. Click or press Escape to close.');
          overlay.innerHTML = '<img alt="" /><p class="tc-lightbox-caption"></p>';
          overlay.addEventListener('click', close);
          document.body.appendChild(overlay);
          return overlay;
        }
        function open(img) {
          var o = ensureOverlay();
          var big = o.querySelector('img');
          big.src = img.currentSrc || img.src;
          big.alt = img.alt || '';
          var fig = img.closest('figure');
          var cap = fig && fig.querySelector('figcaption');
          o.querySelector('.tc-lightbox-caption').textContent = cap ? cap.textContent : '';
          o.classList.add('is-open');
          document.body.style.overflow = 'hidden';
        }
        function close() {
          if (!overlay) return;
          overlay.classList.remove('is-open');
          document.body.style.overflow = '';
        }
        document.addEventListener('click', function (e) {
          var img = e.target.closest('figure img');
          if (!img || e.target.closest('a')) return; // linked images keep their links
          e.preventDefault();
          open(img);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') close();
        });
      })();
    </script>
  </body>
</html>

<style is:global>
  /* Lightbox */
  figure img {
    cursor: zoom-in;
  }
  figure a img {
    cursor: pointer; /* linked images (article/video thumbs) keep link behavior */
  }
  .tc-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: rgba(31, 27, 22, 0.92);
    cursor: zoom-out;
  }
  .tc-lightbox.is-open {
    display: flex;
  }
  .tc-lightbox img {
    max-width: 94vw;
    max-height: 84vh;
    width: auto;
    height: auto;
    border-radius: 4px;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
  }
  .tc-lightbox-caption {
    color: #faf6f0;
    font-style: italic;
    font-size: 0.95rem;
    text-align: center;
    max-width: 70ch;
    margin: 1rem 0 0;
    opacity: 0.85;
  }

  :root {
    --bg: #FAF6F0;        /* same warm off-white as product photos */
    --ink: #1F1B16;
    --muted: #6B6258;
    --rule: #E8DFD3;
    --accent: #8B5E3C;    /* warm brown — heritage feel without being precious */
    --max-width: 1100px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: ui-serif, Georgia, "Iowan Old Style", "Apple Garamond", "Times New Roman", serif;
    background: var(--bg);
    color: var(--ink);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
    width: 100%;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  h1, h2, h3 {
    font-family: ui-serif, Georgia, serif;
    font-weight: 500;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); margin-bottom: 0.75rem; }
  h2 { font-size: 1.5rem; margin: 2.5rem 0 1rem; }
  h3 { font-size: 1.15rem; margin-bottom: 0.5rem; }

  p { margin-bottom: 1rem; }

  a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid currentColor;
  }
  a:hover { opacity: 0.7; }

  .muted { color: var(--muted); font-size: 0.95rem; }

  hr {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 2rem 0;
  }
</style>
