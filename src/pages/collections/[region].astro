---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const regionRoutes = [
    { slug: 'east-asia', regionName: 'East Asia', title: 'East Asia',
      intro: "Tokyo layovers, Korea runs, Auntie Kristen's antique-shop finds in China. Everyone in this circle can end up in Tokyo or Seoul, so East Asia is where our most-tested recommendations come from — the things that get bought again on the next trip, and the one after that, until somebody finally admits it's a ritual. My mom's toiletry kit is half Korean skincare. These aren't really products. They're travel habits." },
    { slug: 'europe', regionName: 'Europe', title: 'Europe',
      intro: "Some souvenirs end up in drawers. These didn't. Italy is Tanya's — she lived there and keeps going back. Germany comes through Auntie Kristen and her longtime German art-dealer friend. The Mainz beer mugs are from a layover trip my parents took; the UK pen came in from Cheryl Lynne. What ties it all together is craftsmanship — beautiful things that survived the trip home and then earned a place in daily life." },
    { slug: 'latin-america', regionName: 'Latin America', title: 'Latin America',
      intro: "These are the items that became family stories. The polenta pan an Argentine restaurant sold to Auntie Kristen after she finished the dish they cooked her in it. The D'Elidas hot sauce she brought back from Panama and won't shut up about. The Costa Rican coffee my mom orders by the bag because suitcase space is finite. Around here, how something entered the family matters as much as what it is." },
    { slug: 'levant', regionName: 'Levant', title: 'Levant',
      intro: "In this collection, the memory leads and the object follows. Old Jerusalem tapestry from a Christmas week my parents spent there together. Istanbul finds from trips we keep going back on. We picked these things up in the moment — and they've been holding those moments ever since." },
    { slug: 'north-america', regionName: 'North America', title: 'North America',
      intro: "This collection is anchored by one question: after thirty years of flying, what survived while everything else got replaced? My mom wears Beverly's pearls every day — the double strand passed down from the same Beverly whose name was painted on a P-40. Underneath them, the working wardrobe she's refined over decades: Talbots and Ann Taylor, Brooks Brothers blouses, Lancôme that lasts a 15-hour flight, and Cozy Earth for the ride home. Less a regional collection, more the toolkit of a life spent traveling.",
      crossLink: { href: '/ladies-business-attire', label: 'The whole working wardrobe, gathered in one place: Ladies Business Attire →' } },
    { slug: 'oceania', regionName: 'Oceania', title: 'Oceania',
      intro: "Small on purpose. A hand-painted boomerang, sourced ethically through an Indigenous Art Code certified retailer. The Felan sweater and leather wallet Auntie Kristen wore home from Sydney. We don't pad collections to make them look full — only things worth remembering earn a place here." },
    { slug: 'travel-gear', regionName: 'Travel Gear', title: 'Travel Gear',
      intro: "Think of this as infrastructure, not shopping. Everything here answers the same question: what problem did it solve so well it never got replaced? My mom has been pulling the same Tumi ottoman out of her travel bag for years — the kind of thing that quietly survives every trip. This is the gear that people who travel constantly actually trust." },
    { slug: 'crew-gear', regionName: 'Crew Gear', title: 'Crew Gear',
      intro: "The flight-deck side of the family. This is the gear our pilots actually fly with — the headset that's logged thousands of hours on my mom's head, the flight bags my dad and cousin swear by, the small stuff that lives in a flight case. Chosen the way everything here is: by people who use it for a living, not because anyone paid to put it on the list." },
    { slug: 'eris', regionName: "Eris's Picks", title: "Eris's Picks",
      intro: "Hey — this is my section. I'm 20, in college, headed for the Air Force after graduation. Everything here passes exactly one test: would I tell my best friend to buy it? Some of these were gifts from Mom (she has good taste). Some I bought myself. Treat this like a gift guide for the college-girl-in-your-life problem. — Eris" },
  ];

  const all = await getCollection('items');
  return regionRoutes.map(r => {
    const items = all.filter(i => i.data.region === r.regionName);
    // Group items by subcategory, preserving original order
    const groups = new Map<string, typeof items>();
    for (const item of items) {
      const subcat = item.data.subcategory || '';
      if (!groups.has(subcat)) groups.set(subcat, []);
      groups.get(subcat)!.push(item);
    }
    // Sort items within each subcategory by itemOrder
    for (const [, list] of groups) {
      list.sort((a, b) => (a.data.itemOrder ?? 0) - (b.data.itemOrder ?? 0));
    }
    // Sort subcategories by subcategoryOrder (using min from items in group)
    const sortedGroups = Array.from(groups.entries()).sort((a, b) => {
      const aOrder = a[1][0]?.data.subcategoryOrder ?? 999;
      const bOrder = b[1][0]?.data.subcategoryOrder ?? 999;
      return aOrder - bOrder;
    });
    return {
      params: { region: r.slug },
      props: { ...r, items, sortedGroups },
    };
  });
}

const { regionName, title, intro, items, sortedGroups, crossLink } = Astro.props;
---

<Layout title={`${title} — Trove Collections`}>
  <header class="collection-header">
    <p class="muted breadcrumb"><a href="/collections">All Collections</a></p>
    <h1>{title}</h1>
    <p class="intro">{intro}</p>
    {crossLink && (
      <p class="cross-link"><a href={crossLink.href}>{crossLink.label}</a></p>
    )}
  </header>

  {items.length === 0 ? (
    <p class="muted empty">No items in this collection yet — coming soon.</p>
  ) : (
    <div class="subcategories">
      {sortedGroups.map(([subcat, list]) => (
        <section class="subcategory">
          {subcat && <h2 class="subcat-header">{subcat}</h2>}
          <div class="grid">
            {list.map((item) => (
              <ProductCard
                name={item.data.name}
                curator={item.data.curator}
                blurb={item.body.slice(0, 220).trim() + (item.body.length > 220 ? '…' : '')}
                photo={item.data.photo}
                additionalPhotos={item.data.additionalPhotos}
                affiliateUrl={item.data.affiliateUrl}
                pendingPhoto={item.data.pendingPhoto}
                slug={item.slug}
              />
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</Layout>

<style>
  .collection-header {
    margin-bottom: 2rem;
  }
  .breadcrumb { margin-bottom: 0.5rem; font-size: 0.9rem; }
  .breadcrumb a { color: var(--muted); border: 0; }
  .intro {
    max-width: 60ch;
    font-size: 1.05rem;
    margin-top: 0.75rem;
  }
  .cross-link {
    margin-top: 0.75rem;
    font-size: 1rem;
  }
  .subcategories {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .subcategory { margin: 0; }
  .subcat-header {
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media (min-width: 600px) {
    .grid { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 900px) {
    .grid { grid-template-columns: 1fr 1fr 1fr; }
  }
  .empty { margin-top: 2rem; font-style: italic; }
</style>
