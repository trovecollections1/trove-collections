---
import Layout from '../layouts/Layout.astro';

const sections = [
  {
    title: 'Grandpa Jim: 1928 → 1972',
    intro: "Lt. Col. James A. Philpott. First solo at 16, in a Velie Mono Coupe. What followed: TWA test pilot, 490th Bombardment Squadron command, Wright Field foreign-aircraft evaluation, KC-135 checkout at Edwards, AMPP president, retired TWA September 1972. Photographs in roughly chronological order.",
    photos: [
      { src: '/images/heritage/grandpa-jim-aviator-portrait.jpg', w: 508, h: 695, caption: "Grandpa Jim as a young aviator — leather helmet, goggles up, and the grin that ran four generations deep." },
      { src: '/images/heritage/grandpa-jim-1928-solo-gift.jpg?v=2', w: 1122, h: 1402, caption: "A commemorative gift marking the 60th anniversary of his first solo on September 8, 1928." },
      { src: '/images/heritage/grandpa-jim-1937-honolulu.jpg?v=2', w: 1122, h: 1402, caption: "Honolulu, 1937. With an Arrow Sport at John Rodgers Airport during the Hawaiian Island Air Races era. Newly surfaced from Aunt Shelly's archive." },
      { src: '/images/heritage/grandpa-jim-p12c.jpg?v=2', w: 1122, h: 1402, caption: "Grandpa Jim in Hap Arnold's P-12C at Randolph Field — early Army Air Corps years." },
      { src: '/images/heritage/grandpa-jim-p12-torrance-coast.jpg', w: 1600, h: 1519, caption: "Air-to-air over the coast near Torrance — Grandpa Jim flying the Boeing P-12E, a 1930s Army pursuit biplane, caught from the chase plane's wing." },
      { src: '/images/heritage/grandpa-jim-p12-torrance-city.jpg', w: 1600, h: 1463, caption: "The P-12E banking over the Torrance airport area, the L.A. basin hazy below — Grandpa Jim at the controls." },
      { src: '/images/heritage/p40-beverly.jpg?v=2', w: 1448, h: 1086, caption: "The P-40 he named *Beverly* after his wife. The framed family copy carries the inscription: \"To the only Beverly, From The Pilot.\"" },
      { src: '/images/heritage/skull-and-wings.jpg?v=2', w: 1448, h: 1086, caption: "The Skull & Wings — designed by Eugene Clay as Grandpa Jim's personal insignia after Pearl Harbor. It flew on the nose of the Lockheed Hudson he ferried to China, then became the 490th's squadron emblem." },
      { src: '/images/heritage/grandpa-jim-beverly-skullwings.jpg', w: 884, h: 671, caption: "Beverly with one of Grandpa Jim's airplanes — a wire-braced, open-cockpit monoplane wearing his personal Skull & Wings, 'Lt Col Philpott' lettered on the cockpit." },
      { src: '/images/heritage/490th-formation.jpg?v=2', w: 1448, h: 1086, caption: "490th Bombardment Squadron in formation. He took command October 20, 1942." },
      { src: '/images/heritage/grandpa-jim-beverly-b25.jpg?v=2', w: 1402, h: 1122, caption: "Grandpa Jim and Beverly with the B-25 *Flagship of the Skull & Wings* — his command ship, painted with war-bonds tour stops on the nose. Beverly visited him at one of them." },
      { src: '/images/heritage/burma-bridge-busters.jpg?v=2', w: 1149, h: 1369, caption: "The 490th 'Burma Bridge Busters' — a North American Aviation B-25 ad that ran in Life magazine, February 5, 1945, saluting the Skull & Wings squadron." },
      { src: '/images/heritage/wright-field-zero.jpg?v=2', w: 1402, h: 1122, caption: "Wright Field. Late-war Foreign Aircraft Evaluation — flight-testing a captured Japanese Zero against US fighters." },
      { src: '/images/heritage/grandpa-jim-hoover-p51.jpg', w: 750, h: 1000, caption: "Grandpa Jim in Bob Hoover's P-51 *Old Yeller* at an airshow. The Hoover friendship began at Edwards in the post-war years." },
      { src: '/images/heritage/grandpa-jim-hoover-80th-birthday.jpg', w: 2000, h: 1367, caption: "Grandpa Jim and Bob Hoover at Jim's 80th birthday — two pals having a cocktail celebration. The shirt says it best: *80 isn't old.*" },
      { src: '/images/heritage/grandpa-jim-pancho-barnes.jpg?v=2', w: 1448, h: 1086, caption: "Grandpa Jim and Pancho Barnes at an OX5 Club function — the club for pilots of the Curtiss OX-5 engine era, ribbons and all. Barnes founded the Associated Motion Picture Pilots; he would later lead it." },
      { src: '/images/heritage/grandpa-jim-ampp.jpg?v=2', w: 1448, h: 1086, caption: "Grandpa Jim at an Associated Motion Picture Pilots event — the Hollywood stunt-pilot guild he served as president. Actor Richard Widmark is among the group." },
      { src: '/images/heritage/grandpa-jim-clark-gable-ampp.jpg', w: 745, h: 924, caption: "Another AMPP gathering — Clark Gable (center), with Grandpa Jim standing just to his left. Gable was a fellow flyer in the Hollywood pilots' circle." },
      { src: '/images/heritage/grandpa-jim-twa.jpg?v=2', w: 1086, h: 1448, caption: "A TWA airframe from his line-pilot years. Hired 1940, retired September 1972." },
      { src: '/images/heritage/grandpa-jim-medals.jpg', w: 1000, h: 750, caption: "Military medals and squadron insignia in the family display case." },
    ],
  },
  {
    title: 'The Hollywood Stearmans',
    intro: "Before the airline years, the family ran an aerial-advertising business out of Torrance Airport. Boeing Stearman PT-17 biplanes in red-and-white sunburst paint, working banner-tow, sky-typing, and TV commercial film aviation.",
    photos: [
      { src: '/images/heritage/grandpa-jim-john-stearman.jpg?v=2', w: 1448, h: 1086, caption: "Grandpa Jim and Captain John Philpott with the family Stearman PT-17. The visual hand-off between Generation 1 and Generation 2." },
      { src: '/images/heritage/aerial-advertising-stearmans.jpg', w: 1100, h: 1442, caption: "The family Stearmans, Hollywood aerial-advertising era — original red-and-white sunburst paint." },
      { src: '/images/heritage/wingwax-aircraft.jpg?v=2', w: 1448, h: 1086, caption: "The 'Wingwax' racer at Torrance Airport — a T-6 that Grandpa Jim and Perry Brown (Beverly's brother — Air Force officer, later a United pilot) modified for racing, pulling the engine and fitting an inverted Ranger in its place. Built to be flown by Jackie Cochran for the Cleveland Air Races." },
    ],
  },
  {
    title: 'Captain John',
    intro: "My grandfather. Aerial Advertising → Sierra Pacific Airways → Continental Airlines, hired October 1972, retired #1 on the seniority list 42 years later. Line Check Airman, A&P-licensed mechanic, six transport types flown across four decades.",
    photos: [
      { src: '/images/heritage/captain-john-23-continental.jpg', w: 557, h: 573, caption: "Fresh out of new-hire training in the early 1970s — a 23-year-old Continental first officer, top row far left, in the airline's 'our special pride' crew brochure." },
      { src: '/images/heritage/captain-john-continental-brochure.jpg', w: 1600, h: 1389, caption: "Continental's 'our special pride' inflight brochure — the whole crew, flight deck to galley. John's just a new hire here; he'd retire 42 years later as #1 on the seniority list." },
      { src: '/images/heritage/captain-john-current.jpg', w: 1200, h: 900, caption: "Captain John at his current aircraft — the post-retirement years are still spent in the air." },
    ],
  },
  {
    title: 'Uncle Tom — married into the family, flying all his own',
    intro: "Uncle Tom married into the family — he wed Lyndi, Grandpa Jim's daughter and Captain John's older sister — and brought a flying life all his own. A Flying Tigers flight engineer on the CL-44 'swingtail' freighters in 1965, military time over Vietnam and Japan, a stint flying an Australian cattle charter, and finally the left seat of the DC-10 and the Boeing 747. His logbook reads like its own adventure novel — coneheads included.",
    photos: [
      { src: '/images/heritage/uncle-tom-first-flights.jpg', w: 1122, h: 1402, caption: "First flights — solo in a Cessna, a new Flying Tigers flight engineer in 1965, the DC-10 alongside Cousin Bill, and finally a Boeing 747 captain." },
      { src: '/images/heritage/uncle-tom-cl44-swingtail.jpg', w: 1122, h: 1402, caption: "Flying Tigers' Canadair CL-44 'swingtail' freighter — the whole tail hinged open to load cargo. Tom as a new flight engineer in 1965, and at the controls." },
      { src: '/images/heritage/uncle-tom-f100-phucat-1966.jpg', w: 1600, h: 1200, caption: "Phu Cat, Vietnam, 1966 — Tom with an F-100 Super Sabre." },
      { src: '/images/heritage/uncle-tom-yokota-japan.jpg', w: 1600, h: 1457, caption: "Yokota Air Base, Japan — Tom in the cockpit, hachimaki and shades." },
      { src: '/images/heritage/uncle-tom-cattle-charter.jpg', w: 1122, h: 1402, caption: "The Australian cattle charter — hauling livestock across the outback, shorts-and-knee-socks crew kit and all." },
      { src: '/images/heritage/uncle-tom-conehead.jpg', w: 1122, h: 1402, caption: "First Officer & Captain Conehead — proof that a long career leaves plenty of room for a sense of humor." },
    ],
  },
  {
    title: 'Generation 3 — the sister captains',
    intro: "My mom Micki, Auntie Kristen, Auntie Angie — three pilots at major US airlines. All three started at the regionals, where the flying is domestic and international right off the bat; Mom's path ran through cargo too, and she flies international today. Auntie Kristen came up through the 737, 757/767, and 787 and flies the 777 today. Auntie Angie came up through the A319/A320 and 737 and flies the 757/767 today.",
    photos: [
      { src: '/images/heritage/family-portrait-4-pilots.jpg?v=2', w: 1086, h: 1448, caption: "Captain John with his three pilot daughters — Generation 2 and Generation 3 in one frame." },
      { src: '/images/heritage/micki-kristen-flying.jpg', w: 404, h: 402, caption: "My mom and Auntie Kristen, flying together back in their regional-airline days — early-morning coffees, getting their mojo going." },
      { src: '/images/heritage/angie-cockpit.jpg', w: 1400, h: 944, caption: "Auntie Angie in the flight-deck doorway — generation three at work." },
      { src: '/images/heritage/john-angie-t28.jpg', w: 1400, h: 1050, caption: "Auntie Angie and my grandfather with the T-28 the family flew back then — Navy trainer colors and all." },
    ],
  },
  {
    title: 'The Y-12 ferry — Kunming → Lusaka',
    intro: "In December 1995, at twenty-five, my mom ferried a Harbin Y-12 from Kunming, China to Lusaka, Zambia for the Zambian Air Force — a multi-leg crossing of Asia and Africa in a twin-turboprop, over the Hump and half the world. The full story ran in The Aviation Geek Club, 'Over the Hump and Half the World.' These are her own photos from the trip, in the order it happened.",
    photos: [
      { src: '/images/heritage/y12-01-kunming.jpg', w: 1600, h: 1024, caption: "Kunming, China — picking up the airplanes, the Chinese completing the paperwork before handover." },
      { src: '/images/heritage/y12-02-micki-swing.jpg', w: 1600, h: 1032, caption: "My mom and her captain, Swing Lindsey, at the airplane in Kunming — the start of the trip." },
      { src: '/images/heritage/y12-03-ramp.jpg', w: 1600, h: 1065, caption: "B-600L on the ramp — registered to China on paper, but wearing Zambian Air Force AF 216 for delivery." },
      { src: '/images/heritage/y12-04-hump.jpg', w: 1600, h: 1032, caption: "Over the Hump — crossing the Himalayas, the same route the China-Burma-India crews flew in the war." },
      { src: '/images/heritage/y12-05-calcutta.jpg', w: 1600, h: 1027, caption: "The ramp at Calcutta — where a jeep came racing out to meet the crew." },
      { src: '/images/heritage/y12-06-villages.jpg', w: 1600, h: 1026, caption: "Small African villages along the way." },
      { src: '/images/heritage/y12-07-kilimanjaro.jpg', w: 1600, h: 1030, caption: "Mount Kilimanjaro on the horizon." },
      { src: '/images/heritage/y12-16-sister-enroute.jpg', w: 1600, h: 1066, caption: "The sister ship, enroute." },
      { src: '/images/heritage/y12-17-sister-desert.jpg', w: 1600, h: 1024, caption: "The sister ship in formation over the desert." },
      { src: '/images/heritage/y12-08-fuel-pumping.jpg', w: 1600, h: 1063, caption: "Hand-pumping Jet A on the wing from the 55-gallon drums they carried along — a home-made fuel stop." },
      { src: '/images/heritage/y12-09-oil-check.jpg', w: 1600, h: 1024, caption: "Up on the wing at dusk — checking the oil." },
      { src: '/images/heritage/y12-10-addis-aerial.jpg', w: 1600, h: 1070, caption: "Aerial over Addis Ababa, Ethiopia — a wrecked airplane sits off the end of the runway." },
      { src: '/images/heritage/y12-11-muscat-bus.jpg', w: 1600, h: 1031, caption: "Muscat — my mom by the Oman Aviation bus." },
      { src: '/images/heritage/y12-12-crew.jpg', w: 1600, h: 1031, caption: "The crew during a fuel stop along the route." },
      { src: '/images/heritage/y12-13-kasama-landing.jpg', w: 1600, h: 1029, caption: "Landing at Kasama, Zambia — a red-dirt strip with thunderstorms stacked behind it." },
      { src: '/images/heritage/y12-14-kasama-ramp.jpg', w: 1600, h: 1030, caption: "Both Y-12s on the red-dirt ramp at Kasama." },
      { src: '/images/heritage/y12-15-zambia-arrival.jpg', w: 1600, h: 1067, caption: "The welcome arrival in Zambia — Cokes, orange sodas, and a toast with the crew." },
    ],
  },
  {
    title: 'Generation 4',
    intro: "My cousin Connor — regional-airline CRJ Captain by day, Pitts S1B aerobatic pilot on weekends. And me — paused for college, will pick it back up someday.",
    photos: [
      { src: '/images/heritage/connor-pitts-s1j.jpg', w: 1200, h: 905, caption: "My cousin Connor with his Pitts S1B." },
      { src: '/images/heritage/connor-pitts-flying.jpg', w: 1400, h: 1050, caption: "Connor aboard the Pitts — N30JP, chevrons and all." },
      { src: '/images/heritage/pitts-airborne.jpg', w: 800, h: 600, caption: "Taxiing in after the cross-country delivery flight — Connor flew the Pitts home himself the day he bought it." },
      { src: '/images/heritage/connor-pitts-formation-golden-hour.jpg', w: 1506, h: 2000, caption: "Connor in N30JP over his buddy Jason's Pitts — two biplanes, one golden-hour frame over Camarillo. *Photo: Alex Cywan*" },
      { src: '/images/heritage/connor-pitts-two-ship-valley.jpg', w: 2000, h: 1126, caption: "The two-ship over the valley — Jason leading, Connor in N30JP. *Photo: Alex Cywan*" },
      { src: '/images/heritage/connor-pitts-n30jp-coast.jpg', w: 1920, h: 1080, caption: "N30JP along the Ventura County coast at golden hour. *Photo: Alex Cywan*" },
      { src: '/images/heritage/eris-first-flight-lesson.jpg', w: 1200, h: 900, caption: "Me, on my first flight lesson — March 2022." },
      { src: '/images/heritage/eris-toddler-757.jpg', w: 1000, h: 1306, caption: "Me, much earlier — in the B757 captain seat as a toddler. The cockpit is family scenery growing up." },
    ],
  },
];
---

<Layout title="The Hangar — Trove Collections" description="A century of photographs from one family's hangar. Four generations of Philpott pilots.">
  <article class="hangar">
    <p class="muted breadcrumb"><a href="/heritage">← Heritage</a></p>

    <h1>The Hangar</h1>
    <p class="lede">
      A century of photographs from one family's hangar — pulled from envelopes,
      shoeboxes, and the wall of my grandfather's den. Roughly chronological.
      Captions where we know the story. The fuller versions live on the
      <a href="/heritage">heritage page</a>.
    </p>

    {sections.map(section => (
      <section class="gen-section">
        <h2>{section.title}</h2>
        <p class="intro">{section.intro}</p>
        <div class="photo-grid">
          {section.photos.map(photo => (
            <figure>
              <img src={photo.src} alt={section.title} width={photo.w} height={photo.h} loading="lazy" />
              <figcaption set:html={photo.caption.replace(/\*([^*]+)\*/g, '<em>$1</em>')}></figcaption>
            </figure>
          ))}
        </div>
      </section>
    ))}

    <hr />

    <p class="muted" style="text-align: center;">
      <a href="/heritage">← Back to Heritage</a> &nbsp; · &nbsp;
      <a href="/stories">Read stories from the road →</a>
    </p>
  </article>
</Layout>

<style>
  .hangar { max-width: 1000px; margin: 0 auto; }
  .breadcrumb { margin-bottom: 1rem; font-size: 0.9rem; }
  .breadcrumb a { color: var(--muted); border: 0; }
  .breadcrumb a:hover { color: var(--ink); }
  .lede {
    font-size: 1.1rem;
    line-height: 1.6;
    max-width: 60ch;
    margin-bottom: 3rem;
  }
  .gen-section { margin: 3rem 0; }
  .gen-section h2 {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--rule);
  }
  .intro {
    max-width: 65ch;
    color: var(--muted);
    font-size: 0.95rem;
    margin-bottom: 1.5rem;
    line-height: 1.55;
  }
  .photo-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 600px) {
    .photo-grid { grid-template-columns: 1fr 1fr; }
  }
  figure { margin: 0; }
  figure img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 4px;
    border: 1px solid var(--rule);
  }
  figure figcaption {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.4;
    font-style: italic;
  }
  hr {
    border: 0;
    border-top: 1px solid var(--rule);
    margin: 3rem 0 2rem;
  }
</style>
